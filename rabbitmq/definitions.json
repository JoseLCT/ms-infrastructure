  "queues": [
    { "name": "ms-logistic-queue", "vhost": "/", "durable": true, "auto_delete": false, "arguments": { "x-dead-letter-exchange": "dead-letter-exchange" } },
    { "name": "ms-kitchen-queue", "vhost": "/", "durable": true, "auto_delete": false, "arguments": { "x-dead-letter-exchange": "dead-letter-exchange" } },

