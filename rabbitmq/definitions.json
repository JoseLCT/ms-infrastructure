      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "orders",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "dead-letter-exchange",
      "vhost": "/",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
